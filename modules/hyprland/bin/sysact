#!/usr/bin/env bash
# sysact - simple power menu for Hyprland/tofi
set -euo pipefail

options=" Lock\nó°’˛ Sleep\nó±Ł» Hibernate\n Reboot\nâŹ» Shutdown"

choice=$(printf "%b" "$options" | tofi)

[ -z "${choice:-}" ] && exit 0

case "$choice" in
" Lock")
  hyprctl dispatch exec "hyprlock" || hyprlock &
  ;;
"ó°’˛ Sleep")
  systemctl suspend
  ;;
"ó±Ł» Hibernate")
  systemctl hibernate
  ;;
" Reboot")
  systemctl reboot
  ;;
"âŹ» Shutdown")
  systemctl poweroff
  ;;
*)
  exit 1
  ;;
esac
